# ─── Supabase ───────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # 서버 전용. 클라이언트에 절대 노출 금지

# ─── ML Service (Phase 1+) ──────────────────────────────
ML_API_URL=http://localhost:8000
ML_API_KEY=...

# ─── Web3 (Phase 3+) ────────────────────────────────────
NEXT_PUBLIC_CHAIN_ID=1
NEXT_PUBLIC_CHR_TOKEN_ADDRESS=0x...
DEPLOYER_PRIVATE_KEY=...                # Hardhat 배포용. 절대 commit 금지
ETHERSCAN_API_KEY=...

# ─── IPFS / Filecoin (Phase 2+) ─────────────────────────
WEB3_STORAGE_TOKEN=...

# ─── Wearable OAuth (Phase 2+) ──────────────────────────
FITBIT_CLIENT_ID=...
FITBIT_CLIENT_SECRET=...
OURA_CLIENT_ID=...
OURA_CLIENT_SECRET=...

# ─── App ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
